# ===== 誠毅傳承自動發文 金鑰範本 =====
# 複製此檔為 .env 並填入實際數值。.env 已被 .gitignore 排除，不會上傳。

# --- Threads（Meta 旗下，需在 developers.facebook.com 申請）---
# THREADS_USER_ID：你的 Threads 帳號 user id（用 me?fields=id 查）
# THREADS_ACCESS_TOKEN：Threads 長期存取權杖（threads_basic + threads_content_publish 權限）
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- Facebook 粉專 ---
# FB_PAGE_ID：粉專的數字 ID
# FB_PAGE_TOKEN：長期粉專存取權杖（教學文件有步驟）
FB_PAGE_ID=
FB_PAGE_TOKEN=

# --- Instagram（商業帳號，需綁定上面的 FB 粉專）---
# IG_USER_ID：IG 商業帳號的 user id
# IG_IMAGE_BASE_URL：圖片公開網址的基底（見教學「IG 圖片網址」一節）
#   例：https://jennyih0227-stack.github.io/chengyi-autopost/posts/images
IG_USER_ID=
IG_IMAGE_BASE_URL=
